{
  "name": "webstrategy/ws-optimizer-ai",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "require": {
    "php": ">=7.4"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.6",
    "10up/wp_mock": "0.5.0",
    "yoast/phpunit-polyfills": "^2.0"
  },
  "autoload-dev": {
    "psr-4": {
      "WS_Optimizer_AI\\Tests\\Unit\\": "tests/unit/"
    }
  },
  "scripts": {
    "test": "phpunit -c phpunit.xml",
    "test:coverage": "phpunit -c phpunit.xml --coverage-clover clover.xml"
  }
}
